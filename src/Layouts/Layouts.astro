---
import { basics } from "@cv";

interface Props {
  title: string;
}

const { title } = Astro.props;

const { image, summary, url } = basics;
const siteUrl = url.endsWith("/") ? url : `${url}/`;
const imageUrl = new URL(image, siteUrl).toString();
const domain = new URL(siteUrl).hostname;
---

<!doctype html>
<html lang="pt-BR" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={summary} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href={image} />

    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={summary} />
    <meta property="og:image" content={imageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={domain} />
    <meta property="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={summary} />
    <meta name="twitter:image" content={imageUrl} />
    <script is:inline>
      (() => {
        const storageKey = "theme";
        const root = document.documentElement;

        const getSavedTheme = () => {
          try {
            return localStorage.getItem(storageKey) === "light" ? "light" : "dark";
          } catch {
            return "dark";
          }
        };

        const setTheme = (theme) => {
          root.dataset.theme = theme;
          root.style.colorScheme = theme;

          try {
            localStorage.setItem(storageKey, theme);
          } catch {}

          window.dispatchEvent(new CustomEvent("themechange", { detail: { theme } }));
        };

        window.setTheme = setTheme;
        window.toggleTheme = () => {
          setTheme(root.dataset.theme === "light" ? "dark" : "light");
        };

        window.addEventListener("toggle-theme", () => window.toggleTheme());
        setTheme(getSavedTheme());
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    --background: #0b0f14;
    --background-radial-primary: rgba(34, 197, 94, 0.14);
    --background-radial-secondary: rgba(56, 189, 248, 0.1);
    --surface: #111827;
    --surface-soft: #172033;
    --surface-hover: #1f2937;
    --text: #f4f7fb;
    --text-muted: #a7b0be;
    --text-subtle: #7f8a9a;
    --border: rgba(255, 255, 255, 0.1);
    --border-strong: rgba(255, 255, 255, 0.18);
    --accent: #22c55e;
    --accent-soft: rgba(34, 197, 94, 0.16);
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      "Courier New",
      Courier,
      monospace;
    background:
      radial-gradient(circle at top left, var(--background-radial-primary), transparent 32rem),
      radial-gradient(circle at 85% 15%, var(--background-radial-secondary), transparent 28rem),
      var(--background);
    color: var(--text);
    letter-spacing: -0.025rem;
    min-height: 100%;
  }

  html[data-theme="light"] {
    --background: #f7f9fc;
    --background-radial-primary: rgba(34, 197, 94, 0.12);
    --background-radial-secondary: rgba(56, 189, 248, 0.14);
    --surface: #fff;
    --surface-soft: #eef2f7;
    --surface-hover: #e7edf5;
    --text: #111827;
    --text-muted: #475569;
    --text-subtle: #64748b;
    --border: rgba(15, 23, 42, 0.1);
    --border-strong: rgba(15, 23, 42, 0.18);
    --accent: #16a34a;
    --accent-soft: rgba(22, 163, 74, 0.12);
  }

  body {
    min-height: 100%;
  }

  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    color: var(--text);
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
  }

  .print {
    display: none !important;
  }

  @media print {
    html {
      --background: #fff;
      --surface: #fff;
      --surface-soft: #f3f3f3;
      --surface-hover: #eee;
      --text: #111;
      --text-muted: #555;
      --text-subtle: #666;
      --border: #ddd;
      --border-strong: #bbb;
      --accent: #111;
      --accent-soft: #eee;
      background: #fff !important;
      color: #111 !important;
    }

    body {
      background: #fff !important;
      color: #111 !important;
    }

    .no-print {
      display: none !important;
    }

    .print {
      display: block !important;
    }

    astro-dev-toolbar {
      display: none !important;
    }

    article {
      break-inside: avoid;
    }

    * {
      box-shadow: none !important;
      text-shadow: none !important;
    }
  }
</style>
