---
import About from "@/components/sections/About.astro";
import Education from "@/components/sections/Education.astro";
import Experience from "@/components/sections/Experience.astro";
import Hero from "@/components/sections/Hero.astro";
import Languages from "@/components/sections/Languages.astro";
import Layouts from "../Layouts/Layouts.astro";
import Projects from "@/components/sections/Projects.astro";
import Skills from "@/components/sections/Skills.astro";
import KeyBoardManager from "@/components/KeyBoardManager.astro";

import { basics } from "@cv";
const { name, label } = basics;
---

<Layouts title={`Portfolio de ${name} - ${label}`}>
  <main>
    <div class="book-layout">
      <div class="book-page book-page-left">
        <div class="book-section hero-section"><Hero /></div>
        <div class="book-section about-section"><About /></div>
        <div class="book-section skills-section"><Skills /></div>
        <div class="book-section languages-section"><Languages /></div>
      </div>

      <div class="book-page book-page-right">
        <div class="book-section experience-section"><Experience /></div>
        <div class="book-section education-section"><Education /></div>
        <div class="book-section projects-section"><Projects /></div>
      </div>
    </div>
  </main>
  <KeyBoardManager />
</Layouts>

<style>
  main {
    margin: auto;
    padding: 4rem;
    width: 100%;
  }

  .book-layout {
    display: flex;
    flex-direction: column;
  }

  .book-page {
    display: contents;
    overflow-x: hidden;
    overflow-y: auto;
  }

  .hero-section {
    order: 1;
  }

  .about-section {
    order: 2;
  }

  .experience-section {
    order: 3;
  }

  .education-section {
    order: 4;
  }

  .projects-section {
    order: 5;
  }

  .skills-section {
    order: 6;
  }

  .languages-section {
    order: 7;
  }

  @media (width >= 1024px) {
    main {
      align-items: center;
      display: flex;
      min-height: 100vh;
      padding: 2rem 2rem 3.75rem;
    }

    .book-layout {
      display: grid;
      gap: 0;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      margin: 0 auto;
      height: min(82vh, 900px);
      max-width: 1400px;
      min-height: 680px;
      perspective: 1800px;
      position: relative;
      width: min(80vw, 1400px);
    }

    .book-layout::before {
      background: linear-gradient(
        90deg,
        transparent,
        rgba(0, 0, 0, 0.28),
        rgba(255, 255, 255, 0.08),
        transparent
      );
      bottom: 18px;
      content: "";
      left: 50%;
      pointer-events: none;
      position: absolute;
      top: 18px;
      transform: translateX(-50%);
      width: 18px;
      z-index: 2;
    }

    .book-page {
      background: color-mix(in srgb, var(--surface) 90%, transparent);
      border: 1px solid var(--border);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.24);
      display: block;
      height: 100%;
      max-height: 100%;
      overflow-y: auto;
      padding: 3rem;
      scrollbar-color: var(--border-strong) transparent;
      scrollbar-width: thin;
      transform-style: preserve-3d;
    }

    .book-page-left {
      border-radius: 26px 0 0 26px;
      border-right: 0;
      transform-origin: right center;
    }

    .book-page-right {
      border-left: 0;
      border-radius: 0 26px 26px 0;
      transform-origin: left center;
    }

    .book-section,
    .book-page :global(section) {
      margin-inline: 0;
      max-width: none;
    }
  }

  @media (width <= 700px) {
    main {
      padding: 2rem;
    }
  }

  @media print {
    main {
      display: block;
      min-height: auto;
      padding: 0;
    }

    .book-layout {
      display: flex;
      flex-direction: column;
    }

    .book-layout::before {
      display: none;
    }

    .book-page {
      background: transparent;
      border: 0;
      box-shadow: none;
      display: contents;
      height: auto;
      max-height: none;
      overflow: visible;
      padding: 0;
    }
  }
</style>
