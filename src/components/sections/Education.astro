---
import Area from "@/components/Area.astro";
import { education } from "@cv";

const getYear = (date?: string | null) => {
  if (!date?.trim()) return null;

  const parsedDate = new Date(date);

  if (Number.isNaN(parsedDate.getTime())) return null;

  return parsedDate.getFullYear();
};
---

<Area title="Educação">
  <ul>
    {
      education.map(({ institution, startDate, endDate, area }) => {
        const startYear = getYear(startDate);
        const endYear = getYear(endDate);
        const years = [startYear, endYear].filter(Boolean).join(" - ");

        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>{institution}</h3>
                </div>

                {years && <time>{years}</time>}
              </header>

              <footer>
                <p>{area}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Area>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: #111;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: #555;
    font-size: 0.85rem;
    min-width: 102px;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
