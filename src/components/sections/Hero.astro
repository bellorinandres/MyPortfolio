---
import { basics } from "@cv";
import Area from "@/components/Area.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
const { name, label, location, email, image, profiles } = basics;

import Mail from "@/icons/Mail.astro";

import GitHub from "@/icons/GitHub.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import X from "@/icons/X.astro";

const SOCIAL_ICONS = {
  GitHub,
  LinkedIn,
  X,
};
---

<Area>
  <div class="container">
    <div class="info">
      <h1>{name}</h1>
      <h2>{label}</h2>
      <span>
        {location.city}, {location.postalCode} - {location.region}
      </span>
      {email && <p class="print-email print">E-mail: {email}</p>}

      <footer class="no-print">
        {
          email && (
            <a
              href={`mailto:${email}`}
              aria-label={`Enviar e-mail para ${name}`}
              title={`Enviar e-mail para ${name}: ${email}`}
            >
              <Mail />
            </a>
          )
        }

        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network as keyof typeof SOCIAL_ICONS];

            if (!Icon) return null;

            return (
              <a
                href={url}
                aria-label={`Visitar perfil de ${name} en ${network}`}
                title={`Visitar perfil de ${name} em ${network}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon />
              </a>
            );
          })
        }
        <ThemeToggle />
      </footer>
    </div>
    <figure>
      <img src={image} alt={name} width="128" height="128" decoding="async" fetchpriority="high" />
    </figure>
  </div>
</Area>

<style>
  .container {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-right: 32px;
  }

  h1 {
    font-size: 2rem;
  }

  h2 {
    color: var(--text-muted);
    font-weight: 500;
    font-size: 1.1rem;
    text-wrap: balance;
  }

  img {
    aspect-ratio: 1 / 1;
    border: 1px solid var(--border-strong);
    object-fit: cover;
    width: 128px;
    border-radius: 16px;
  }

  span {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
    letter-spacing: -0.05rem;
  }

  footer {
    align-items: center;
    color: var(--text-subtle);
    font-size: 0.65rem;
    display: flex;
    gap: 6px;
    margin-top: 8px;
  }

  footer a {
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
    border: 1px solid var(--border);
    line-height: 0;
    padding: 4px;
    height: 36px;
    width: 36px;
    border-radius: 6px;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  footer a:hover {
    background: var(--surface-hover);
    border: 1px solid var(--border-strong);
    color: var(--text);
  }

  footer a :global(svg) {
    display: block;
    height: 18px;
    width: 18px;
  }

  .print-email {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.35rem;
  }

  @media (width <= 700px) {
    .container {
      flex-direction: column-reverse;
    }

    .info {
      justify-content: center;
      align-items: center;
      padding-right: 0;
      text-align: center;
    }

    figure {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    h2 {
      text-wrap: balance;
    }

    figure {
      margin: 0 auto;
    }
  }
</style>
