---
import Area from "@/components/Area.astro";
import { work } from "@cv";

const getYear = (date?: string | null) => {
  if (!date?.trim()) return null;

  const parsedDate = new Date(date);

  if (Number.isNaN(parsedDate.getTime())) return null;

  return parsedDate.getFullYear();
};
---

<Area title="Experiência profissional">
  <ul>
    {
      work.map(
        ({ name, startDate, endDate, position, summary, highlights, url }) => {
          const startYear = getYear(startDate);
          const endYear = getYear(endDate) ?? "Atual";

          return (
            <li>
              <article>
                <header>
                  <div>
                    <h3>
                      {url ? (
                        <a
                          href={url}
                          title={`Ver ${name}`}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {name}
                        </a>
                      ) : (
                        name
                      )}
                    </h3>
                    <h4>{position}</h4>
                  </div>

                  <div>
                    <time datetime={startDate} data-title={startDate}>
                      {startYear}
                    </time>
                    {" - "}
                    <time datetime={endDate ?? undefined} data-title={endDate ?? "Atual"}>
                      {endYear}
                    </time>
                  </div>
                </header>

                <footer>
                  <p>{summary}</p>
                  {highlights.length > 0 && (
                    <ul class="highlights">
                      {highlights.map((highlight) => (
                        <li>{highlight}</li>
                      ))}
                    </ul>
                  )}
                </footer>
              </article>
            </li>
          );
        }
      )
    }
  </ul>
</Area>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: var(--text);
  }

  article a {
    color: var(--text);
  }

  article a:hover {
    text-decoration: underline;
  }

  article h4 {
    color: var(--text-muted);
    font-weight: 400;
  }

  article footer {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .highlights {
    color: var(--text-muted);
    display: flex;
    flex-direction: column;
    font-size: 0.8rem;
    gap: 4px;
    list-style: disc;
    padding-left: 1rem;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: var(--text-subtle);
    font-size: 0.85rem;
    min-width: 102px;
    cursor: default;
  }

  [data-title]:hover:after {
    opacity: 1;
    transition:
      opacity 0.1s ease-in-out 0.5s,
      visibility 0.1s ease-in-out 0.5s;
    visibility: visible;
  }

  [data-title]:after {
    content: attr(data-title);
    background-color: var(--surface-hover);
    color: var(--text);
    font-size: 0.75rem;
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      "Courier New",
      monospace;
    position: absolute;
    padding: 0.2rem 0.5rem;
    bottom: -1.4rem;
    left: 50%;
    white-space: nowrap;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
    opacity: 0;
    border: 1px solid var(--border-strong);
    z-index: 99999;
    visibility: hidden;
    border-radius: 6px;
  }

  [data-title] {
    position: relative;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
