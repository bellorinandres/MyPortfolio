---
import Area from "@/components/Area.astro";
import HTML from "@/icons/html.astro";
import CSS from "@/icons/css.astro";
import JavaScript from "@/icons/javascript.astro";
import TypeScript from "@/icons/type.astro";
import React from "@/icons/react.astro";
import Node from "@/icons/node.astro";
import Python from "@/icons/python.astro";
import MySQL from "@/icons/sql.astro";
import Git from "@/icons/git.astro";
import GitHub from "@/icons/GitHub.astro";
import Tailwind from "@/icons/tailwind.astro";
import Next from "@/icons/next.astro";
import { skills } from "@cv";
import Swift from "@/icons/swift.astro";
import SwiftUI from "@/icons/swiftui.astro";
import Kotlin from "@/icons/kotlin.astro";
import Flutter from "@/icons/flutter.astro";

const SKILLS_ICONS = {
  HTML,
  CSS,
  JavaScript,
  TypeScript,
  React,
  Node,
  Python,
  MySQL,
  Git,
  GitHub,
  Next,
  Tailwind,
  Swift,
  SwiftUI,
  Kotlin,
  Flutter,
};
---

<Area title="Habilidades">
  <ul>
    {
      skills.map(({ name, level, keywords }) => {
        const iconName =
          {
            "Next.js": "Next",
            "Node.js": "Node",
          }[name] ?? name;
        const Icon = SKILLS_ICONS[iconName as keyof typeof SKILLS_ICONS];

        return (
          <li>
            <div class="skill-title">
              {Icon && <Icon />}
              <strong>{name}</strong>
              <span>{level}</span>
            </div>
            {keywords.length > 0 && <small>{keywords.join(" • ")}</small>}
          </li>
        );
      })
    }
  </ul>
</Area>

<style>
  ul {
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  li {
    background: #eee;
    border-radius: 6px;
    color: black;
    display: grid;
    font-size: 0.8rem;
    font-weight: 500;
    gap: 4px;
    padding: 0.2rem 0.6rem;
  }

  .skill-title {
    align-items: center;
    display: flex;
    gap: 4px;
  }

  .skill-title span,
  small {
    color: #555;
    font-weight: 400;
  }

  small {
    font-size: 0.68rem;
  }
</style>
